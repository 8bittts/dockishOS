# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon[]
._*
.Spotlight-V100
.Trashes

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Local build / packaging artifacts (icons, DMGs, staging)
build/*
!build/dockishos.png
!build/yen.png
dist/

# Xcode
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.hmap
*.xcuserstate
*.xcscmblueprint
*.xccheckout
DerivedData/

# App packaging
*.ipa
*.dSYM
*.dSYM.zip
*.app
# Sparkle ships Updater.app as the progress/authorization helper inside the
# vendored framework; without it, in-app updates fail to launch the installer.
!tools/sparkle/Sparkle.framework/Versions/*/Updater.app
!tools/sparkle/Sparkle.framework/Versions/*/Updater.app/**

# Editor / tooling
.vscode/
.idea/
*.swp
*.swo

# Agent docs / local tool state
CLAUDE.md
AGENTS.md
.claude/

# Local environment / secrets
.env
.env.local
*.pem
*.p8
*.p12
